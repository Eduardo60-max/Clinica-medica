-- BANCO DE DADOS: CLÍNICA MÉDICA
-- PostgreSQL 

-- nova  tabela clinica

-- 1. TABELAS DE PESSOAS E PROFISSIONAIS

CREATE TABLE IF NOT EXISTS Clinica (
    ID       SERIAL PRIMARY KEY,
    Nome     VARCHAR(100) NOT NULL,
    CNPJ     VARCHAR(20) UNIQUE NOT NULL,
    Endereco VARCHAR(255),
    Telefone VARCHAR(20)
);

CREATE TABLE IF NOT EXISTS Medico (
    ID           SERIAL PRIMARY KEY,
    ClinicaID    INT NOT NULL,
    Nome         VARCHAR(100) NOT NULL,
    Telefone     VARCHAR(20),
    CRM          VARCHAR(30) UNIQUE NOT NULL,
    Especialidade VARCHAR(50),
    Salario      NUMERIC(10,2),
    Senha        VARCHAR(255),
    CONSTRAINT fk_medico_clinica FOREIGN KEY (ClinicaID)
        REFERENCES Clinica(ID)
);

CREATE TABLE IF NOT EXISTS Funcionario (
    ID        SERIAL PRIMARY KEY,
    ClinicaID INT NOT NULL,
    Nome      VARCHAR(100) NOT NULL,
    Telefone  VARCHAR(20),
    CPF       VARCHAR(20) UNIQUE NOT NULL,
    Cargo     VARCHAR(50),
    Salario   NUMERIC(10,2),
    CONSTRAINT fk_funcionario_clinica FOREIGN KEY (ClinicaID)
        REFERENCES Clinica(ID)
);

CREATE TABLE IF NOT EXISTS Paciente (
    ID             SERIAL PRIMARY KEY,
    Nome           VARCHAR(100) NOT NULL,
    Email          VARCHAR(100),
    CPF            VARCHAR(20) UNIQUE,
    Endereco       VARCHAR(255),
    Telefone       VARCHAR(20),
    DataNascimento DATE NOT NULL,
    Sexo           VARCHAR(20)
);

-- 2. TABELAS DE ATENDIMENTO E REGISTRO

CREATE TABLE IF NOT EXISTS Agendamento (
    ID            SERIAL PRIMARY KEY,
    ClinicaID     INT NOT NULL,
    PacienteID    INT NOT NULL,
    MedicoID      INT NOT NULL,
    FuncionarioID INT NOT NULL,
    DataHora      TIMESTAMP NOT NULL,
    Status        VARCHAR(20) NOT NULL DEFAULT 'AGENDADO',
    Observacao    TEXT,
    CONSTRAINT fk_agendamento_clinica FOREIGN KEY (ClinicaID)
        REFERENCES Clinica(ID),
    CONSTRAINT fk_agendamento_paciente FOREIGN KEY (PacienteID)
        REFERENCES Paciente(ID),

    CONSTRAINT fk_agendamento_medico FOREIGN KEY (MedicoID)
        REFERENCES Medico(ID),
    CONSTRAINT fk_agendamento_funcionario FOREIGN KEY (FuncionarioID)
        REFERENCES Funcionario(ID),
        
    CONSTRAINT chk_agendamento_status
        CHECK (Status IN ('AGENDADO', 'CONFIRMADO', 'CANCELADO', 'REALIZADO'))
);

CREATE TABLE IF NOT EXISTS Atendimento (
    ID             SERIAL PRIMARY KEY,
    AgendamentoID  INT,
    MedicoID       INT NOT NULL,
    PacienteID     INT NOT NULL,
    Descricao      TEXT,
    Tipo           VARCHAR(50),
    DataAtendimento TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    Status         VARCHAR(20) DEFAULT 'ATIVO',
    CONSTRAINT fk_atendimento_agendamento FOREIGN KEY (AgendamentoID)
        REFERENCES Agendamento(ID)
        ON DELETE SET NULL,
    CONSTRAINT fk_atendimento_medico FOREIGN KEY (MedicoID)
        REFERENCES Medico(ID),
    CONSTRAINT fk_atendimento_paciente FOREIGN KEY (PacienteID)
        REFERENCES Paciente(ID),
        
    CONSTRAINT chk_atendimento_status
        CHECK (Status IN ('ATIVO', 'CANCELADO', 'CONCLUIDO')),
    CONSTRAINT uq_atendimento_agendamento (AgendamentoID)
);

CREATE TABLE IF NOT EXISTS Prontuario (
    ID             SERIAL PRIMARY KEY,
    AtendimentoID  INT,
    PacienteID     INT NOT NULL,
    MedicoID       INT NOT NULL,
    Descricao      TEXT,
    DataRegistro   DATE DEFAULT CURRENT_DATE,
    CONSTRAINT fk_prontuario_atendimento FOREIGN KEY (AtendimentoID)
        REFERENCES Atendimento(ID)
        ON DELETE SET NULL,
    CONSTRAINT fk_prontuario_paciente FOREIGN KEY (PacienteID)
        REFERENCES Paciente(ID),
        
    CONSTRAINT fk_prontuario_medico FOREIGN KEY (MedicoID)
        REFERENCES Medico(ID),
        
);

-- 3. TABELAS DE AGENDA E TRANSAÇÃO

CREATE TABLE IF NOT EXISTS Transacao (
    ID              SERIAL PRIMARY KEY,
    AtendimentoID   INT NOT NULL,
    Preco           NUMERIC(10,2),
    Tipo_Pagamento  VARCHAR(50),
    StatusPagamento VARCHAR(20) DEFAULT 'PENDENTE',
    DataPagamento   TIMESTAMP,
    CONSTRAINT fk_transacao_atendimento FOREIGN KEY (AtendimentoID)
        REFERENCES Atendimento(ID),
        
    CONSTRAINT chk_transacao_status
        CHECK (StatusPagamento IN ('PENDENTE', 'PAGO', 'CANCELADO'))
);

-- 4. TABELAS DE ESTOQUE E PRODUTO

CREATE TABLE IF NOT EXISTS Produto (
    ID        SERIAL PRIMARY KEY,
    Nome      VARCHAR(100) NOT NULL,
    Descricao TEXT,
    Preco     NUMERIC(10,2) NOT NULL
);

CREATE TABLE IF NOT EXISTS Estoque (
    ID          SERIAL PRIMARY KEY,
    ProdutoID   INT NOT NULL,
    Quantidade  INT DEFAULT 0,
    Localizacao VARCHAR(50),
    CONSTRAINT fk_estoque_produto FOREIGN KEY (ProdutoID)
        REFERENCES Produto(ID)
        ON DELETE CASCADE
);

-- 5. TABELA DE RELACIONAMENTO (Transação <-> Produto)

CREATE TABLE IF NOT EXISTS Transacao_Produto (
    TransacaoID INT NOT NULL,
    ProdutoID   INT NOT NULL,
    Quantidade  INT DEFAULT 1,
    PRIMARY KEY (TransacaoID, ProdutoID),
    CONSTRAINT fk_transproduto_transacao FOREIGN KEY (TransacaoID)
        REFERENCES Transacao(ID)
        ON DELETE CASCADE,
    CONSTRAINT fk_transproduto_produto FOREIGN KEY (ProdutoID)
        REFERENCES Produto(ID)
        ON DELETE RESTRICT
);


