
-- BANCO DE DADOS: CLÍNICA MÉDICA
-- PostgreSQL 



-- 1. TABELAS DE PESSOAS E PROFISSIONAIS


CREATE TABLE IF NOT EXISTS Medico (
    ID SERIAL PRIMARY KEY,
    Nome VARCHAR(100) NOT NULL,
    Telefone VARCHAR(20),
    CRM VARCHAR(30) UNIQUE NOT NULL,
    Especialidade VARCHAR(50),
    Salario NUMERIC(10,2)
);

CREATE TABLE IF NOT EXISTS Funcionario (
    ID SERIAL PRIMARY KEY,
    Nome VARCHAR(100) NOT NULL,
    Telefone VARCHAR(20),
    CPF VARCHAR(20) UNIQUE NOT NULL,
    Cargo VARCHAR(50),
    Salario NUMERIC(10,2)
);

CREATE TABLE IF NOT EXISTS Paciente (
    ID SERIAL PRIMARY KEY,
    Nome VARCHAR(100) NOT NULL,
    Email VARCHAR(100),
    CPF VARCHAR(20) UNIQUE,
    Endereco VARCHAR(255),
    Telefone VARCHAR(20),
    DataNascimento DATE NOT NULL,
    Sexo VARCHAR(20),
    MedicoID INT NOT NULL, 
    
    CONSTRAINT fk_paciente_medico
        FOREIGN KEY (MedicoID) 
        REFERENCES Medico(ID) 
        ON DELETE RESTRICT 
);


-- 2. TABELAS DE ATENDIMENTO E REGISTRO


CREATE TABLE IF NOT EXISTS Atendimento (
    ID SERIAL PRIMARY KEY,
    MedicoID INT NOT NULL,
    PacienteID INT NOT NULL,
    Descricao TEXT,
    Tipo VARCHAR(50),
    Preco NUMERIC(10,2),
    DataHora TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    Status VARCHAR(20) DEFAULT 'ATIVO',
    
    CONSTRAINT fk_atendimento_medico
        FOREIGN KEY (MedicoID) 
        REFERENCES Medico(ID) 
        ON DELETE RESTRICT,
        
    CONSTRAINT fk_atendimento_paciente
        FOREIGN KEY (PacienteID) 
        REFERENCES Paciente(ID) 
        ON DELETE RESTRICT,
        
    CONSTRAINT chk_atendimento_status CHECK (Status IN ('ATIVO', 'CANCELADO', 'CONCLUIDO'))
);

CREATE TABLE IF NOT EXISTS Prontuario (
    ID SERIAL PRIMARY KEY,
    PacienteID INT NOT NULL,
    MedicoID INT NOT NULL,
    Descricao TEXT,
    DataRegistro DATE DEFAULT CURRENT_DATE,
    
    CONSTRAINT fk_prontuario_paciente
        FOREIGN KEY (PacienteID) 
        REFERENCES Paciente(ID) 
        ON DELETE CASCADE,
        
    CONSTRAINT fk_prontuario_medico
        FOREIGN KEY (MedicoID) 
        REFERENCES Medico(ID) 
        ON DELETE RESTRICT
);


-- 3. TABELAS DE AGENDA E TRANSAÇÃO


CREATE TABLE IF NOT EXISTS Agenda (
    ID SERIAL PRIMARY KEY,
    FuncionarioID INT NOT NULL,
    AtendimentoID INT NOT NULL,
    DataAgenda TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    Status VARCHAR(20) DEFAULT 'AGENDADO',
    
    CONSTRAINT fk_agenda_funcionario
        FOREIGN KEY (FuncionarioID) 
        REFERENCES Funcionario(ID) 
        ON DELETE RESTRICT,
        
    CONSTRAINT fk_agenda_atendimento
        FOREIGN KEY (AtendimentoID) 
        REFERENCES Atendimento(ID) 
        ON DELETE CASCADE, 
        
    CONSTRAINT uq_agenda_atendimento UNIQUE (AtendimentoID),
    
    CONSTRAINT chk_agenda_status CHECK (Status IN ('AGENDADO', 'CONFIRMADO', 'CANCELADO', 'REALIZADO'))
);


CREATE TABLE IF NOT EXISTS Transacao (
    ID SERIAL PRIMARY KEY,
    AtendimentoID INT NOT NULL,
    Preco NUMERIC(10,2),
    Tipo_Pagamento VARCHAR(50),
    StatusPagamento VARCHAR(20) DEFAULT 'PENDENTE',
    DataPagamento TIMESTAMP, 
    
    CONSTRAINT fk_transacao_atendimento
        FOREIGN KEY (AtendimentoID) 
        REFERENCES Atendimento(ID) 
        ON DELETE RESTRICT,
        
    CONSTRAINT chk_transacao_status CHECK (StatusPagamento IN ('PENDENTE', 'PAGO', 'CANCELADO'))
);


-- 4. TABELAS DE ESTOQUE E PRODUTO


CREATE TABLE IF NOT EXISTS Produto (
    ID SERIAL PRIMARY KEY,
    Nome VARCHAR(100) NOT NULL,
    Descricao TEXT,
    Preco NUMERIC(10,2) NOT NULL
);

CREATE TABLE IF NOT EXISTS Estoque (
    ID SERIAL PRIMARY KEY,
    ProdutoID INT NOT NULL,
    Quantidade INT DEFAULT 0,
    Localizacao VARCHAR(50),
    
    CONSTRAINT fk_estoque_produto
        FOREIGN KEY (ProdutoID) 
        REFERENCES Produto(ID) 
        ON DELETE CASCADE
);


-- 5. TABELA DE RELACIONAMENTO (Transação <-> Produto)


CREATE TABLE IF NOT EXISTS Transacao_Produto (
    TransacaoID INT NOT NULL,
    ProdutoID INT NOT NULL,
    Quantidade INT DEFAULT 1,
    
    PRIMARY KEY (TransacaoID, ProdutoID),
    
    CONSTRAINT fk_transproduto_transacao
        FOREIGN KEY (TransacaoID) 
        REFERENCES Transacao(ID) 
        ON DELETE CASCADE,
        
    CONSTRAINT fk_transproduto_produto
        FOREIGN KEY (ProdutoID) 
        REFERENCES Produto(ID) 
        ON DELETE RESTRICT
);


