-- 8. TRIGGERS


CREATE OR REPLACE FUNCTION validar_data_nascimento_paciente()
RETURNS TRIGGER AS $$
DECLARE
    idade_limite INT := 120;
BEGIN
    IF NEW.DataNascimento > CURRENT_DATE THEN
        RAISE EXCEPTION 'A Data de Nascimento não pode ser no futuro.';
    END IF;

    IF AGE(CURRENT_DATE, NEW.DataNascimento) > MAKE_INTERVAL(years := idade_limite) THEN
        RAISE EXCEPTION 'A idade excede o limite permitido de % anos.', idade_limite;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trigger_validar_data_nascimento_paciente
    BEFORE INSERT OR UPDATE ON Paciente
    FOR EACH ROW
    EXECUTE FUNCTION validar_data_nascimento_paciente();

CREATE OR REPLACE FUNCTION validar_conflito_agendamento()
RETURNS TRIGGER AS $$
BEGIN
    IF EXISTS (
        SELECT 1 FROM Agendamento
        WHERE MedicoID = NEW.MedicoID
          AND DataHora  = NEW.DataHora
          AND Status NOT IN ('CANCELADO')
          AND ID != COALESCE(NEW.ID, -1)
    ) THEN
        RAISE EXCEPTION 'Médico já possui agendamento neste horário.';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trigger_conflito_agendamento
    BEFORE INSERT OR UPDATE ON Agendamento
    FOR EACH ROW
    EXECUTE FUNCTION validar_conflito_agendamento();

CREATE OR REPLACE FUNCTION atualizar_estoque_transacao_produto()
RETURNS TRIGGER AS $$
DECLARE
    v_produto_id             INT;
    v_quantidade_movimentada INT;
BEGIN
    IF TG_OP = 'INSERT' THEN
        v_produto_id             := NEW.ProdutoID;
        v_quantidade_movimentada := -NEW.Quantidade;
    ELSIF TG_OP = 'DELETE' THEN
        v_produto_id             := OLD.ProdutoID;
        v_quantidade_movimentada := OLD.Quantidade;
    END IF;

    UPDATE Estoque
    SET Quantidade = Quantidade + v_quantidade_movimentada
    WHERE ProdutoID = v_produto_id;

    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE TRIGGER trigger_controle_estoque
    AFTER INSERT OR DELETE ON Transacao_Produto
    FOR EACH ROW
    EXECUTE FUNCTION atualizar_estoque_transacao_produto();


