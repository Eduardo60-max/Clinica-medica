-- 2. CONSTRAINTS ADICIONAIS DE VALIDAÇÃO


-- Tabela Medico
ALTER TABLE Medico
ADD CONSTRAINT chk_medico_salario_positivo CHECK (Salario >= 0);

-- Tabela Paciente
ALTER TABLE Paciente
ADD CONSTRAINT chk_paciente_idade_positiva CHECK (Idade >= 0),
ADD CONSTRAINT chk_paciente_sexo_valido CHECK (Sexo IN ('M', 'F', 'O')); 

-- Tabela Funcionario
ALTER TABLE Funcionario
ADD CONSTRAINT chk_funcionario_salario_positivo CHECK (Salario >= 0);

-- Tabela Atendimento
ALTER TABLE Atendimento
ADD CONSTRAINT chk_atendimento_preco_positivo CHECK (Preco >= 0);

-- Tabela Produto
ALTER TABLE Produto
ADD CONSTRAINT chk_produto_preco_positivo CHECK (Preco > 0);

-- Tabela Estoque
ALTER TABLE Estoque
ADD CONSTRAINT chk_estoque_quantidade_nao_negativa CHECK (Quantidade >= 0);

-- Tabela Transacao
ALTER TABLE Transacao
ADD CONSTRAINT chk_transacao_preco_positivo CHECK (Preco >= 0);




-- 3. TRIGGERS (VALIDAÇÃO E FUNCIONALIDADR)



CREATE OR REPLACE FUNCTION validar_idade_paciente()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.Idade IS NOT NULL AND (NEW.Idade < 0 OR NEW.Idade > 110) THEN
        RAISE EXCEPTION 'A idade do paciente deve ser um valor razoável (entre 0 e 110 anos).';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;


CREATE TRIGGER trigger_validar_idade_paciente
    BEFORE INSERT OR UPDATE ON Paciente
    FOR EACH ROW
    EXECUTE FUNCTION validar_idade_paciente();



CREATE OR REPLACE FUNCTION atualizar_estoque_transacao_produto()
RETURNS TRIGGER AS $$
DECLARE
    v_produto_id INT;
    v_quantidade_movimentada INT;
BEGIN
    -
    IF (TG_OP = 'INSERT') THEN
        v_produto_id := NEW.ProdutoID;
        v_quantidade_movimentada := NEW.Quantidade * -1;
    ELSIF (TG_OP = 'DELETE') THEN
        v_produto_id := OLD.ProdutoID;    
        v_quantidade_movimentada := OLD.Quantidade;
    ELSE
        
        RETURN NULL; 
    END IF;

    
    UPDATE Estoque
    SET Quantidade = Quantidade + v_quantidade_movimentada
    WHERE ProdutoID = v_produto_id;

    
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Erro: Produto com ID % não encontrado na tabela Estoque.', v_produto_id;
    END IF;

    
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;


-- TRIGGER: Aciona a transação

CREATE TRIGGER trigger_controle_estoque
AFTER INSERT OR DELETE ON Transacao_Produto
FOR EACH ROW
EXECUTE FUNCTION atualizar_estoque_transacao_produto();