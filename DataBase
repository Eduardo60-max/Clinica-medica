-- 8. TRIGGERS 



CREATE OR REPLACE FUNCTION validar_data_nascimento_paciente()
RETURNS TRIGGER AS $$
DECLARE
    idade_limite INT := 120;
BEGIN
    IF NEW.DataNascimento IS NULL THEN
        RAISE EXCEPTION 'A Data de Nascimento é obrigatória.';
    END IF;

    IF NEW.DataNascimento > CURRENT_DATE THEN
        RAISE EXCEPTION 'A Data de Nascimento não pode ser no futuro.';
    END IF;
    
    IF (CURRENT_DATE - NEW.DataNascimento) / 365.25 > idade_limite THEN
        RAISE EXCEPTION 'A idade calculada excede o limite de % anos.', idade_limite;
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_validar_data_nascimento_paciente
    BEFORE INSERT OR UPDATE ON Paciente
    FOR EACH ROW
    EXECUTE FUNCTION validar_data_nascimento_paciente();



CREATE OR REPLACE FUNCTION atualizar_estoque_transacao_produto()
RETURNS TRIGGER AS $$
DECLARE
    v_produto_id INT;
    v_quantidade_movimentada INT;
BEGIN
    IF (TG_OP = 'INSERT') THEN
        v_produto_id := NEW.ProdutoID;
        v_quantidade_movimentada := NEW.Quantidade * -1;
    ELSIF (TG_OP = 'DELETE') THEN
        v_produto_id := OLD.ProdutoID;    
        v_quantidade_movimentada := OLD.Quantidade;
    ELSE
        RETURN NULL; 
    END IF;
    
    UPDATE Estoque
    SET Quantidade = Quantidade + v_quantidade_movimentada
    WHERE ProdutoID = v_produto_id;
    
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Erro: Produto com ID % nao encontrado na tabela Estoque.', v_produto_id;
    END IF;
    
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_controle_estoque
AFTER INSERT OR DELETE ON Transacao_Produto
FOR EACH ROW
EXECUTE FUNCTION atualizar_estoque_transacao_produto();